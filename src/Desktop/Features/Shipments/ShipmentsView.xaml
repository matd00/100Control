<UserControl x:Class="Desktop.Features.Shipments.ShipmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <Style x:Key="SBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="STb" TargetType="TextBox">
            <Setter Property="Background" Value="#FAFBFD"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Gestão de Envios" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                    <TabItem Header="Envios Locais">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <ItemsControl ItemsSource="{Binding Shipments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="16" Margin="0,0,0,10" Cursor="Hand" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                    <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Enviado">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                            <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Entregue">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                            <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Cancelado">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                            <Setter Property="BorderBrush" Value="#FECACA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectShipmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Id, StringFormat='ENV-{0:N8}'}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                        <Border Background="#F59E0B" CornerRadius="5" Padding="6,2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Background="#FFFBEB" CornerRadius="5" Padding="6,2" Margin="4,0,0,0" BorderBrush="#FDE68A" BorderThickness="1">
                                                            <TextBlock Text="{Binding ProviderText}" FontSize="10" Foreground="#B45309"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding TrackingNumber, StringFormat='Rastreio: {0}'}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0"/>
                                                    <TextBlock Text="{Binding DateFormatted, Mode=OneWay}" FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding CostFormatted, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Etiquetas SuperFrete">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Content="Atualizar" Command="{Binding RefreshSuperFreteCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Margin="0,0,0,12" Height="34"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SuperFreteLabels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="16" Margin="0,0,0,10" Cursor="Hand" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FAFBFD"/>
                                                        <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="released">
                                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                                <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="posted">
                                                                <Setter Property="Background" Value="#ECFDF5"/>
                                                                <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                <Setter Property="Background" Value="#ECFDF5"/>
                                                                <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectSuperFreteLabelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding ReceiverName}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                            <Border Background="#3B82F6" CornerRadius="5" Padding="6,2" Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding TrackingCode, StringFormat='Rastreio: {0}'}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding DateFormatted, Mode=OneWay}" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding OrderId}" FontSize="11" Opacity="0.4" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource CardContainer}">
            <StackPanel>
                <TextBlock Text="Novo Envio" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18"/>
                <TextBlock Text="Pedido" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding PendingOrders}" SelectedItem="{Binding SelectedOrder}" DisplayMemberPath="Description" Margin="0,0,0,12" Padding="10"/>
                <TextBlock Text="Transportadora" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" Margin="0,0,0,16" Padding="10"/>
                <Button Content="Criar Envio" Command="{Binding CreateShipmentCommand}" Background="#6366F1" Style="{StaticResource SBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,20"/>
                <Border Background="#FAFBFD" CornerRadius="10" Padding="14" BorderBrush="#F1F5F9" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedShipment, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSuperFreteLabel, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="ITEM SELECIONADO" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Visibility="{Binding SelectedShipment, Converter={StaticResource NullToVisibility}}">
                            <TextBlock Text="{Binding SelectedShipment.CostFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,4,0,12"/>
                            <TextBlock Text="Código de Rastreio" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource STb}" Text="{Binding TrackingNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            <TextBlock Text="Custo do Frete" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource STb}" Text="{Binding ShippingCost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <Button Content="Gerar Etiqueta" Command="{Binding GenerateLabelCommand}" Background="#3B82F6" Style="{StaticResource SBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding SelectedSuperFreteLabel, Converter={StaticResource NullToVisibility}}">
                            <TextBlock Text="{Binding SelectedSuperFreteLabel.ReceiverName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,4,0,4"/>
                            <TextBlock Text="{Binding SelectedSuperFreteLabel.TrackingCode}" FontSize="13" Foreground="#3B82F6" Margin="0,0,0,12"/>
                            <Button Content="Pagar Etiqueta" Command="{Binding CheckoutLabelCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SBtn}">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSuperFreteLabel.IsPaid}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Atualizar Status" Command="{Binding RefreshLabelStatusCommand}" Background="#3B82F6" Style="{StaticResource SBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        </StackPanel>
                        <Button Content="Imprimir Etiqueta" Command="{Binding PrintLabelCommand}" Background="#10B981" Style="{StaticResource SBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="{Binding SelectedShipment, Converter={StaticResource NullToVisibility}}">
                            <Button Content="Enviado" Command="{Binding MarkAsShippedCommand}" Background="#6366F1" Style="{StaticResource SBtn}" Margin="0,0,8,0"/>
                            <Button Content="Entregue" Command="{Binding MarkAsDeliveredCommand}" Background="#3B82F6" Style="{StaticResource SBtn}"/>
                        </StackPanel>
                        <Button Content="Rastrear" Command="{Binding TrackShipmentCommand}" Background="#475569" Style="{StaticResource SBtn}" HorizontalAlignment="Stretch" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
