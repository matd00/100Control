<UserControl x:Class="Desktop.Features.Orders.FactoryOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             xmlns:domain="clr-namespace:Domain.Entities;assembly=Domain"
             Background="#F0F2F5">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:BoolToLoadingTextConverter x:Key="BoolToLoadingText"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F59E0B"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KPI Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="📋 Total Pedidos" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsTotalOrders}" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                <StackPanel>
                    <TextBlock Text="💰 Receita" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsTotalRevenue, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#22C55E" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                <StackPanel>
                    <TextBlock Text="📦 Custo Total" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsTotalCost, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock Text="📊 Margem Média" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsAverageMargin, StringFormat='{}{0:N1}%'}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ToolBar with search -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="🔄 Atualizar" Command="{Binding RefreshOrdersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#1E293B" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Search box -->
                <Grid Grid.Column="1" MaxWidth="300" HorizontalAlignment="Right" Margin="12,0,12,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" Padding="32,10,12,10"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="#94A3B8" IsHitTestVisible="False"/>
                </Grid>

                <!-- Status filter -->
                <ComboBox Grid.Column="2" SelectedItem="{Binding StatusFilter}" Margin="0,0,12,0" 
                          MinWidth="140" VerticalAlignment="Center" FontSize="13" Padding="8,6">
                    <ComboBox.Items>
                        <ComboBoxItem Content="Todos os Status"/>
                    </ComboBox.Items>
                </ComboBox>

                <Button Grid.Column="3" Content="+ Novo Pedido Fábrica" Command="{Binding NewOrderCommand}" Style="{StaticResource SuccessButton}"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid Section -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                <DataGrid ItemsSource="{Binding Orders}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          SelectionMode="Single"
                          SelectedItem="{Binding SelectedOrder}"
                          Background="White"
                          RowHeight="54"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAtFormatted, Mode=OneWay}" Width="Auto"/>
                        <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTemplateColumn Header="Status" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusBackgroundColor}" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Venda" Binding="{Binding TotalSalePriceFormatted, Mode=OneWay}" Width="Auto"/>
                        <DataGridTemplateColumn Header="Ações" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Command="{Binding DataContext.SyncWithSuperFreteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Sincronizar Rastreio"
                                                Visibility="{Binding HasTrackingCode, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="🔄" FontSize="14"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Excluir Pedido" Margin="8,0,0,0">
                                            <TextBlock Text="🗑️" FontSize="14" Foreground="#EF4444"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            
            <!-- ===== Editing Form ===== -->
            <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Novo Pedido Fábrica" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,24"/>
                        
                        <!-- Customer Picker Section -->
                        <Border Background="#F0F9FF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="👤 Selecionar Cliente Cadastrado" FontSize="14" FontWeight="SemiBold" Foreground="#0369A1" Margin="0,0,0,12"/>
                                
                                <TextBox Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                                
                                <ListBox ItemsSource="{Binding FilteredCustomers}" MaxHeight="150" BorderThickness="0" Background="Transparent"
                                         SelectedItem="{Binding SelectedCustomer}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,4">
                                                <TextBlock Text="👤" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#1E293B"/>
                                                    <TextBlock FontSize="11" Foreground="#64748B">
                                                        <Run Text="{Binding Phone}"/> — <Run Text="{Binding Email}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <TextBlock Text="ou preencha manualmente abaixo" FontSize="11" Foreground="#94A3B8" Margin="0,8,0,0" 
                                           Visibility="{Binding HasSelectedCustomer, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Customer fields -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nome do Cliente *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.CustomerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="WhatsApp / E-mail *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.CustomerContact, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Endereço Completo Entrega *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding SelectedOrder.DeliveryAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                        
                        <!-- Supplier + Channel -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nome da Fábrica *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.SupplierName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contato da Fábrica" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.SupplierContact, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" MinWidth="150">
                                <TextBlock Text="Canal" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <ComboBox SelectedItem="{Binding SelectedOrder.Channel}" FontSize="14" Padding="10,8" MinWidth="140">
                                    <domain:OrderSource>Direct</domain:OrderSource>
                                    <domain:OrderSource>MercadoLivre</domain:OrderSource>
                                    <domain:OrderSource>Shopee</domain:OrderSource>
                                    <domain:OrderSource>Instagram</domain:OrderSource>
                                    <domain:OrderSource>WhatsApp</domain:OrderSource>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Observações" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding SelectedOrder.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                        
                        <!-- Items section -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,16" Padding="0,16,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="📦 Itens do Pedido" FontSize="16" FontWeight="SemiBold"/>
                                    <Button Content="+ Adicionar Item" Command="{Binding AddItemCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="12,6"/>
                                </Grid>
                                
                                <!-- Item header -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Descrição" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="1" Text="Qtd" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Custo Un." FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="Venda Un." FontWeight="SemiBold" Foreground="#64748B"/>
                                </Grid>
                                
                                <ItemsControl ItemsSource="{Binding SelectedOrder.Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0" TextAlignment="Center"/>
                                                <TextBox Grid.Column="2" Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="3" Text="{Binding UnitSalePrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                <Button Grid.Column="4" Content="✕" 
                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        
                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                            <Button Content="Cancelar" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" Padding="24,12"/>
                            <Button Content="💾 Salvar Pedido" Command="{Binding SaveOrderCommand}" Style="{StaticResource PrimaryButton}" Padding="24,12"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== Details Sidebar ===== -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                <Grid>
                    <TextBlock Text="Selecione um pedido" 
                               Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibility}}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8"/>
                               
                    <ScrollViewer Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibility}}" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Detalhes do Pedido" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                            
                            <!-- Status Badge -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{Binding SelectedOrder.StatusBackgroundColor}" Padding="10,5" CornerRadius="6" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SelectedOrder.StatusText}" Foreground="{Binding SelectedOrder.StatusColor}" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>
                            
                            <!-- Tracking (if exists) -->
                            <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,16" Visibility="{Binding SelectedOrder.HasTrackingCode, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="📦 Rastreio da Fábrica" FontSize="10" FontWeight="Bold" Foreground="#0284C7"/>
                                    <TextBlock Text="{Binding SelectedOrder.TrackingCode}" FontSize="14" FontWeight="Bold" Foreground="#0369A1" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Customer info -->
                            <TextBlock Text="👤 CLIENTE" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedOrder.CustomerName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SelectedOrder.CustomerContact}" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="{Binding SelectedOrder.DeliveryAddress}" FontSize="12" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,16"/>
                            
                            <!-- Supplier info -->
                            <TextBlock Text="🏭 FÁBRICA" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedOrder.SupplierName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SelectedOrder.SupplierContact}" FontSize="12" Foreground="#64748B" Margin="0,0,0,16"/>
                            
                            <!-- Items -->
                            <TextBlock Text="📋 ITENS" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding SelectedOrder.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,6,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Description}" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="11" Foreground="#64748B">
                                                        <Run Text="{Binding Quantity, Mode=OneWay}"/>x <Run Text="{Binding UnitSalePriceFormatted, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding SubtotalSalePriceFormatted, Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Financial summary -->
                            <Border BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Margin="0,16,0,16" Padding="0,16,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Preço de Venda" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedOrder.TotalSalePriceFormatted, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Custo da Fábrica" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedOrder.TotalCostFormatted, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#EF4444"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="Margem Bruta" FontSize="12" FontWeight="Bold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding SelectedOrder.MarginFormatted, Mode=OneWay}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#22C55E"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Tracking code input (for MarkSent) -->
                            <Border Background="#FFFBEB" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                    Visibility="{Binding CanMarkSent, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="📦 Código de Rastreio" FontSize="11" FontWeight="Bold" Foreground="#92400E" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding TrackingCodeInput, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="Enviar" Command="{Binding MarkSentCommand}" Style="{StaticResource WarningButton}" Padding="12,8"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Smart Status Action Buttons -->
                            <TextBlock Text="⚡ AÇÕES" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,8"/>
                            
                            <Button Content="✅ Confirmar Pedido" 
                                    Command="{Binding ConfirmOrderCommand}" 
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Padding="12,10"
                                    Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVisibility}}"/>

                            <Button Content="🚚 Marcar Entregue" 
                                    Command="{Binding MarkDeliveredCommand}" 
                                    Style="{StaticResource SuccessButton}" Margin="0,0,0,8" Padding="12,10"
                                    Visibility="{Binding CanMarkDelivered, Converter={StaticResource BoolToVisibility}}"/>
                                    
                            <Button Content="❌ Cancelar Pedido" 
                                    Command="{Binding CancelOrderCommand}" 
                                    Style="{StaticResource DangerButton}" Margin="0,0,0,8" Padding="12,10"
                                    Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
