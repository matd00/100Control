<UserControl x:Class="Desktop.Features.Orders.FactoryOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             xmlns:domain="clr-namespace:Domain.Entities;assembly=Domain"
             Background="#F0F2F5">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KPI Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Total Pedidos Fábrica" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsTotalOrders}" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                <StackPanel>
                    <TextBlock Text="Receita (Fábrica)" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsTotalRevenue, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#22C55E" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                <StackPanel>
                    <TextBlock Text="Custo Total" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsTotalCost, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock Text="Margem Média" FontSize="13" Foreground="#64748B"/>
                    <TextBlock Text="{Binding MetricsAverageMargin, StringFormat='{}{0:N2} %'}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ToolBar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="🔄 Atualizar" Command="{Binding RefreshOrdersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#1E293B" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <Button Grid.Column="2" Content="+ Novo Pedido Fábrica" Command="{Binding NewOrderCommand}" Style="{StaticResource SuccessButton}"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid Section -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                <DataGrid ItemsSource="{Binding Orders}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          SelectionMode="Single"
                          SelectedItem="{Binding SelectedOrder}"
                          Background="White"
                          RowHeight="40"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAtFormatted}" Width="Auto"/>
                        <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Fornecedor" Binding="{Binding SupplierName}" Width="*"/>
                        <DataGridTextColumn Header="Venda" Binding="{Binding TotalSalePriceFormatted}" Width="Auto"/>
                        <DataGridTextColumn Header="Margem" Binding="{Binding MarginFormatted}" Width="Auto"/>
                        <DataGridTemplateColumn Header="Status" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusBackgroundColor}" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding DataContext.SelectOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    </DataGrid.InputBindings>
                </DataGrid>
            </Border>
            
            <!-- Editing Form (Takes up the whole grid when IsEditing is True) -->
            <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Novo Pedido Fábrica" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,24"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nome do Cliente *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.CustomerName}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="WhatsApp/E-mail *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.CustomerContact}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Endereço Completo Entrega *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding SelectedOrder.DeliveryAddress}" Style="{StaticResource ModernTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nome da Fábrica *" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.SupplierName}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contato da Fábrica" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SelectedOrder.SupplierContact}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Observações" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding SelectedOrder.Notes}" Style="{StaticResource ModernTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                        
                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,16" Padding="0,16,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="📦 Itens do Pedido" FontSize="16" FontWeight="SemiBold"/>
                                    <Button Content="+ Adicionar Item" Command="{Binding AddItemCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="12,6"/>
                                </Grid>
                                
                                <!-- Header dos items -->
                                <Grid Margin="0,0,0,8" Visibility="{Binding SelectedOrder.ItemsCount, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Descrição" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="1" Text="Qtd" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Custo Un." FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="Venda Un." FontWeight="SemiBold" Foreground="#64748B"/>
                                </Grid>
                                
                                <ItemsControl ItemsSource="{Binding SelectedOrder.Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding Description}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding Quantity}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0" TextAlignment="Center"/>
                                                <TextBox Grid.Column="2" Text="{Binding UnitCost}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="3" Text="{Binding UnitSalePrice}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                <Button Grid.Column="4" Content="✕" 
                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0" Cursor="Hand"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                            <Button Content="Cancelar" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" Padding="24,12"/>
                            <Button Content="Salvar Pedido" Command="{Binding SaveOrderCommand}" Style="{StaticResource PrimaryButton}" Padding="24,12"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Details Sidebar (Only visible when an order is selected but NOT editing) -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                <Grid>
                    <TextBlock Text="Selecione um pedido" 
                               Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibility}}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8"/>
                               
                    <ScrollViewer Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibility}}" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Detalhes" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                            
                            <!-- Badges -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{Binding SelectedOrder.StatusBackgroundColor}" Padding="8,4" CornerRadius="4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SelectedOrder.StatusText}" Foreground="{Binding SelectedOrder.StatusColor}" FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            
                            <!-- Tracking (se existir) -->
                            <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,16" Visibility="{Binding SelectedOrder.HasTrackingCode, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Rastreio da Fábrica" FontSize="10" FontWeight="Bold" Foreground="#0284C7"/>
                                    <TextBlock Text="{Binding SelectedOrder.TrackingCode}" FontSize="14" FontWeight="Bold" Foreground="#0369A1" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Cliente" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedOrder.CustomerName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SelectedOrder.CustomerContact}" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="{Binding SelectedOrder.DeliveryAddress}" FontSize="12" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,16"/>
                            
                            <TextBlock Text="Fábrica" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedOrder.SupplierName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SelectedOrder.SupplierContact}" FontSize="12" Foreground="#64748B" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Itens" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding SelectedOrder.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,4,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Description}" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="11" Foreground="#64748B">
                                                        <Run Text="{Binding Quantity}"/>x <Run Text="{Binding UnitSalePriceFormatted}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding SubtotalSalePriceFormatted}" FontSize="12" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <Border BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Margin="0,16,0,16" Padding="0,16,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Preço de Venda" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedOrder.TotalSalePriceFormatted}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Custo da Fábrica" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedOrder.TotalCostFormatted}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#EF4444"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="Margem Bruta" FontSize="12" FontWeight="Bold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding SelectedOrder.MarginFormatted}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#22C55E"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Ações de Status" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Button Content="Marcar como Confirmado" 
                                    Command="{Binding UpdateStatusCommand}" 
                                    CommandParameter="{x:Static domain:FactoryOrderStatus.Confirmado}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Padding="12,8"/>
                            
                            <Button Content="Marcar como Entregue" 
                                    Command="{Binding UpdateStatusCommand}" 
                                    CommandParameter="{x:Static domain:FactoryOrderStatus.Entregue}"
                                    Style="{StaticResource SuccessButton}" Margin="0,0,0,8" Padding="12,8"/>
                                    
                            <Button Content="Cancelar Pedido" 
                                    Command="{Binding UpdateStatusCommand}" 
                                    CommandParameter="{x:Static domain:FactoryOrderStatus.Cancelado}"
                                    Background="#FEF2F2" Foreground="#DC2626" BorderThickness="0" Padding="12,8" Cursor="Hand" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
