<UserControl x:Class="Desktop.Features.Orders.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             xmlns:local="clr-namespace:Desktop.Features.Orders"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <local:StepToBrushConverter x:Key="StepToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Order List -->
        <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,14,0" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="20,18,20,10">
                    <StackPanel>
                        <TextBlock Text="Pedidos" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,14"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}"
                                 materialDesign:HintAssist.Hint="Buscar pedidos..."
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox SelectedValue="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}" 
                                      Style="{StaticResource ModernComboBox}"
                                      materialDesign:HintAssist.Hint="Categoria"
                                      Height="42">
                                <ComboBoxItem Content="Todas Categorias" IsSelected="True"/>
                                <ComboBoxItem Content="Kits de Peças" />
                                <ComboBoxItem Content="Cilindros de CO2" />
                                <ComboBoxItem Content="Válvulas de CO2" />
                                <ComboBoxItem Content="Cilindros de HPA" />
                                <ComboBoxItem Content="Válvulas de HPA" />
                                <ComboBoxItem Content="Geral" />
                            </ComboBox>
                            <Button Grid.Column="1" Command="{Binding RefreshOrdersCommand}" 
                                    Style="{StaticResource MaterialDesignIconButton}" Margin="8,0,0,0" Width="36" Height="36">
                                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Grid.Row="1" Content="NOVO PEDIDO" Command="{Binding NewOrderCommand}" 
                        Style="{StaticResource ModernButton}" 
                        Margin="20,6,20,14" Height="40"/>

                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredOrders}" 
                         SelectedItem="{Binding SelectedOrder}"
                         Style="{StaticResource MaterialDesignNavigationPrimaryListBox}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding CustomerName}" FontWeight="Medium" FontSize="13.5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0" Opacity="0.5">
                                            <materialDesign:PackIcon Kind="ClockOutline" Width="13" Height="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CreatedAtFormatted}" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding TotalFormatted}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" FontSize="13"/>
                                        <Border CornerRadius="6" Padding="6,2" Margin="0,3,0,0" HorizontalAlignment="Right">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Shipped">
                                                            <Setter Property="Background" Value="{DynamicResource InfoLightBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1">
            <Border Style="{StaticResource CardContainer}" Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CartOutline" Width="64" Height="64" Opacity="0.08" HorizontalAlignment="Center"/>
                    <TextBlock Text="Selecione ou crie um pedido" FontSize="15" Opacity="0.35" Margin="0,20,0,0" FontWeight="Medium"/>
                    <Button Content="CRIAR PEDIDO" Command="{Binding NewOrderCommand}" Style="{StaticResource SecondaryButton}" Margin="0,24,0,0" Height="38"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardContainer}" Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibility}}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Stepper -->
                    <Border Padding="28,20" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" CornerRadius="15" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Account" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16"/>
                                    </Border>
                                    <TextBlock Text="Cliente" VerticalAlignment="Center" Margin="10,0,20,0" FontWeight="Medium" FontSize="13"/>
                                </StackPanel>
                                <materialDesign:PackIcon Kind="ChevronRight" Opacity="0.2" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <StackPanel Orientation="Horizontal" Opacity="{Binding Step1Completed, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=0.3}">
                                    <Border Width="30" Height="30" CornerRadius="15" Background="{Binding CurrentStep, Converter={StaticResource StepToBrushConverter}, ConverterParameter=2}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="PackageVariant" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16"/>
                                    </Border>
                                    <TextBlock Text="Produtos" VerticalAlignment="Center" Margin="10,0,20,0" FontWeight="Medium" FontSize="13"/>
                                </StackPanel>
                                <materialDesign:PackIcon Kind="ChevronRight" Opacity="0.2" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <StackPanel Orientation="Horizontal" Opacity="{Binding Step2Completed, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=0.3}">
                                    <Border Width="30" Height="30" CornerRadius="15" Background="{Binding CurrentStep, Converter={StaticResource StepToBrushConverter}, ConverterParameter=3}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="TruckDelivery" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16"/>
                                    </Border>
                                    <TextBlock Text="Envio" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Medium" FontSize="13"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CancelOrderCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource DangerBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="CANCELAR" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" Padding="28,20" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- Step 1 -->
                            <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Selecionar Cliente" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                <ListBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" MaxHeight="400" Style="{StaticResource MaterialDesignNavigationPrimaryListBox}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13.5"/>
                                                    <TextBlock Text="{Binding Email}" Opacity="0.5" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <!-- Step 2 -->
                            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Adicionar Produtos" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                    <ItemsControl ItemsSource="{Binding AvailableProducts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CardContainerFlat}" Margin="0,0,0,10" Padding="14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13.5"/>
                                                            <TextBlock Text="{Binding PriceFormatted}" Foreground="{StaticResource SuccessBrush}" FontSize="13"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Command="{Binding DataContext.AddProductToOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="34" Height="34">
                                                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Pedido Atual" FontWeight="SemiBold" Margin="0,0,0,14" FontSize="14"/>
                                        <ItemsControl ItemsSource="{Binding OrderItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ProductName}" FontSize="12.5"/>
                                                            <TextBlock Text="{Binding SubtotalFormatted}" FontWeight="SemiBold" Opacity="0.6" FontSize="12"/>
                                                        </StackPanel>
                                                        <Button HorizontalAlignment="Right" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="22" Height="22">
                                                            <materialDesign:PackIcon Kind="Close" Width="12" Height="12"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Separator Margin="0,12"/>
                                        <Grid>
                                            <TextBlock Text="Total" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding OrderTotalFormatted}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" Foreground="{StaticResource SuccessBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Step 3 -->
                            <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Opções de Envio" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                <Border Padding="20" CornerRadius="12" Margin="0,0,0,20">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#6366F1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="MapMarker" Width="20" Height="20" Foreground="White"/>
                                        <StackPanel Margin="36,0,0,0">
                                            <TextBlock Text="Destino" Opacity="0.7" FontSize="11.5" Foreground="White"/>
                                            <TextBlock Text="{Binding DestinationPostalCode}" FontWeight="SemiBold" FontSize="15" Foreground="White"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Content="ALTERAR" FontSize="11"/>
                                    </Grid>
                                </Border>
                                <Button Command="{Binding CalculateShippingCommand}" Style="{StaticResource ModernButton}" Height="44" IsEnabled="{Binding IsCalculatingShipping, Converter={StaticResource InverseBool}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Calculator" VerticalAlignment="Center" Width="18" Height="18"/>
                                        <TextBlock Text="CALCULAR FRETE" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <ProgressBar IsIndeterminate="True" Margin="0,20,0,0" Visibility="{Binding IsCalculatingShipping, Converter={StaticResource BoolToVisibility}}"/>
                                <ItemsControl ItemsSource="{Binding ShippingQuotes}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardContainerFlat}" Margin="0,0,0,10" Padding="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon Kind="Truck" VerticalAlignment="Center" Width="20" Height="20" Opacity="0.4"/>
                                                    <StackPanel Grid.Column="1" Margin="14,0">
                                                        <TextBlock Text="{Binding ServiceName}" FontWeight="Medium" FontSize="13"/>
                                                        <TextBlock Text="{Binding DeliveryRange}" FontSize="12" Opacity="0.5"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{Binding PriceFormatted}" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right" FontSize="13"/>
                                                        <Button Content="SELECIONAR" Style="{StaticResource MaterialDesignFlatButton}" Padding="6,2" Height="Auto" FontSize="11" Command="{Binding DataContext.SelectShippingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2" Padding="28,16" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Button HorizontalAlignment="Left" Content="ANTERIOR" Command="{Binding PreviousStepCommand}" Style="{StaticResource SecondaryButton}" Visibility="{Binding IsStep1, Converter={StaticResource InverseBoolToVisibility}}" Height="38"/>
                            <Button HorizontalAlignment="Right" Content="PRÓXIMO" Command="{Binding NextStepCommand}" Style="{StaticResource ModernButton}" Visibility="{Binding IsStep3, Converter={StaticResource InverseBoolToVisibility}}" IsEnabled="{Binding Step1Completed}" Height="38"/>
                            <Button HorizontalAlignment="Right" Content="FINALIZAR PEDIDO" Command="{Binding FinalizeOrderCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}" IsEnabled="{Binding HasSelectedShipping}" Height="38"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
