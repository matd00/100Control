<UserControl x:Class="Desktop.Features.Orders.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             xmlns:local="clr-namespace:Desktop.Features.Orders"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <local:StepToBrushConverter x:Key="StepToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Order List -->
        <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search and Filters -->
                <StackPanel Grid.Row="0" Padding="20,20,20,10">
                    <TextBlock Text="Orders" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Search orders..."
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox SelectedValue="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Category"
                                  Height="45">
                            <ComboBoxItem Content="Todas Categorias" IsSelected="True"/>
                            <ComboBoxItem Content="Kits de Peças" />
                            <ComboBoxItem Content="Cilindros de CO2" />
                            <ComboBoxItem Content="Válvulas de CO2" />
                            <ComboBoxItem Content="Cilindros de HPA" />
                            <ComboBoxItem Content="Válvulas de HPA" />
                            <ComboBoxItem Content="Geral" />
                        </ComboBox>
                        <Button Grid.Column="1" Command="{Binding RefreshOrdersCommand}" 
                                Style="{StaticResource MaterialDesignIconButton}" Margin="8,0,0,0">
                            <materialDesign:PackIcon Kind="Refresh" />
                        </Button>
                    </Grid>
                </StackPanel>

                <Button Grid.Row="1" Content="NEW ORDER" Command="{Binding NewOrderCommand}" 
                        Style="{StaticResource MaterialDesignRaisedButton}" 
                        Margin="20,10" Height="45" materialDesign:ButtonAssist.CornerRadius="12"/>

                <!-- Orders List -->
                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredOrders}" 
                         SelectedItem="{Binding SelectedOrder}"
                         Style="{StaticResource MaterialDesignNavigationPrimaryListBox}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,12" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding CustomerName}" FontWeight="Bold" FontSize="14"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Opacity="0.6">
                                            <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CreatedAtFormatted}" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding TotalFormatted}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                        <Border CornerRadius="10" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Right">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Shipped">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </materialDesign:Card>

        <!-- RIGHT PANEL: Wizard / Details -->
        <Grid Grid.Column="1">
            <!-- Empty State -->
            <materialDesign:Card Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibility}}"
                                 UniformCornerRadius="16" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CartOutline" Width="80" Height="80" Opacity="0.1" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an order or create a new one" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Opacity="0.4" Margin="0,24,0,0"/>
                    <Button Content="CREATE NEW ORDER" Command="{Binding NewOrderCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,32,0,0"
                            materialDesign:ButtonAssist.CornerRadius="12"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Wizard Flow -->
            <materialDesign:Card Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibility}}"
                                 UniformCornerRadius="16" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Stepper Header -->
                    <Border Grid.Row="0" Padding="32,24" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Step 1 -->
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Account" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Customer" VerticalAlignment="Center" Margin="12,0,24,0" FontWeight="SemiBold"/>
                                </StackPanel>
                                
                                <materialDesign:PackIcon Kind="ChevronRight" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,24,0"/>

                                <!-- Step 2 -->
                                <StackPanel Orientation="Horizontal" Opacity="{Binding Step1Completed, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=0.3}">
                                    <Border Width="32" Height="32" CornerRadius="16" 
                                            Background="{Binding CurrentStep, Converter={local:StepToBrushConverter}, ConverterParameter=2}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="PackageVariant" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Products" VerticalAlignment="Center" Margin="12,0,24,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <materialDesign:PackIcon Kind="ChevronRight" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,24,0"/>

                                <!-- Step 3 -->
                                <StackPanel Orientation="Horizontal" Opacity="{Binding Step2Completed, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=0.3}">
                                    <Border Width="32" Height="32" CornerRadius="16" 
                                            Background="{Binding CurrentStep, Converter={local:StepToBrushConverter}, ConverterParameter=3}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="TruckDelivery" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Shipping" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{Binding CancelOrderCommand}" 
                                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource DangerBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="CANCEL" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <ScrollViewer Grid.Row="1" Padding="32" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- Step 1: Customer -->
                            <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Select Customer" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,24"/>
                                <ListBox ItemsSource="{Binding Customers}" 
                                         SelectedItem="{Binding SelectedCustomer}"
                                         MaxHeight="400"
                                         Style="{StaticResource MaterialDesignNavigationPrimaryListBox}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Email}" Opacity="0.6" FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <!-- Step 2: Products -->
                            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="350"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                    <TextBlock Text="Add Products" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,24"/>
                                    <ItemsControl ItemsSource="{Binding AvailableProducts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <materialDesign:Card Margin="0,0,0,12" Padding="16">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding PriceFormatted}" Foreground="{StaticResource SuccessBrush}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Command="{Binding DataContext.AddProductToOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}">
                                                            <materialDesign:PackIcon Kind="Plus" />
                                                        </Button>
                                                    </Grid>
                                                </materialDesign:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <materialDesign:Card Grid.Column="1" Padding="24" Background="#F8FAFC" UniformCornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Current Order" FontWeight="Bold" Margin="0,0,0,16"/>
                                        <ItemsControl ItemsSource="{Binding OrderItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ProductName}" FontSize="12"/>
                                                            <TextBlock Text="{Binding SubtotalFormatted}" FontWeight="Bold" Opacity="0.7"/>
                                                        </StackPanel>
                                                        <Button HorizontalAlignment="Right" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24">
                                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Separator Margin="0,16"/>
                                        <Grid>
                                            <TextBlock Text="Total"/>
                                            <TextBlock Text="{Binding OrderTotalFormatted}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="18" Foreground="{StaticResource SuccessBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </materialDesign:Card>
                            </Grid>

                            <!-- Step 3: Shipping -->
                            <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Shipping Options" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,24"/>
                                
                                <materialDesign:Card Padding="24" Margin="0,0,0,24" Background="{StaticResource PrimaryBrush}" Foreground="White" UniformCornerRadius="16">
                                    <Grid>
                                        <materialDesign:PackIcon Kind="MapMarker" Width="24" Height="24"/>
                                        <StackPanel Margin="40,0,0,0">
                                            <TextBlock Text="Destination" Opacity="0.7" FontSize="12"/>
                                            <TextBlock Text="{Binding DestinationPostalCode}" FontWeight="Bold" FontSize="16"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Content="CHANGE"/>
                                    </Grid>
                                </materialDesign:Card>

                                <Button Command="{Binding CalculateShippingCommand}" 
                                        Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Height="50" materialDesign:ButtonAssist.CornerRadius="12"
                                        IsEnabled="{Binding IsCalculatingShipping, Converter={StaticResource InverseBool}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Calculate" VerticalAlignment="Center"/>
                                        <TextBlock Text="CALCULATE SHIPPING" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                                <ProgressBar IsIndeterminate="True" Margin="0,24,0,0" 
                                             Visibility="{Binding IsCalculatingShipping, Converter={StaticResource BoolToVisibility}}"/>

                                <ItemsControl ItemsSource="{Binding ShippingQuotes}" Margin="0,24,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <materialDesign:Card Margin="0,0,0,12" Padding="16" materialDesign:ShadowAssist.ShadowDepth="Depth0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon Kind="Truck" VerticalAlignment="Center" Width="24" Height="24" Opacity="0.5"/>
                                                    <StackPanel Grid.Column="1" Margin="16,0">
                                                        <TextBlock Text="{Binding ServiceName}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding DeliveryRange}" FontSize="12" Opacity="0.6"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{Binding PriceFormatted}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/>
                                                        <Button Content="SELECT" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Height="Auto"
                                                                Command="{Binding DataContext.SelectShippingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </materialDesign:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Navigation Footer -->
                    <Border Grid.Row="2" Padding="32,20" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Button HorizontalAlignment="Left" Content="PREVIOUS" 
                                    Command="{Binding PreviousStepCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Visibility="{Binding IsStep1, Converter={StaticResource InverseBoolToVisibility}}"
                                    materialDesign:ButtonAssist.CornerRadius="12"/>
                            
                            <Button HorizontalAlignment="Right" Content="NEXT STEP" 
                                    Command="{Binding NextStepCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Visibility="{Binding IsStep3, Converter={StaticResource InverseBoolToVisibility}}"
                                    IsEnabled="{Binding Step1Completed}"
                                    materialDesign:ButtonAssist.CornerRadius="12"/>

                            <Button HorizontalAlignment="Right" Content="FINALIZE ORDER" 
                                    Command="{Binding FinalizeOrderCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource SuccessBrush}"
                                    BorderBrush="{StaticResource SuccessBrush}"
                                    Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}"
                                    IsEnabled="{Binding HasSelectedShipping}"
                                    materialDesign:ButtonAssist.CornerRadius="12"/>
                        </Grid>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>