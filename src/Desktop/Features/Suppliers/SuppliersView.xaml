<UserControl x:Class="Desktop.Features.Suppliers.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             Background="#F0F2F5">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:BoolToEditTextConverter x:Key="BoolToEditText"/>
        
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de Fornecedores -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🚚 Fornecedores" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding Suppliers.Count, StringFormat=' ({0})'}" FontSize="14" Foreground="#64748B" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Width="300" Orientation="Horizontal">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}" Width="250"
                                 ToolTip="Buscar por Nome, Contato, Email ou Documento"/>
                        <Button Content="✕" Command="{Binding ClearSearchCommand}" Style="{StaticResource SecondaryButton}" 
                                Padding="8,4" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Header -->
                <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="EMPRESA / CONTATO" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="1" Text="TELEFONE" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="2" Text="CIDADE" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    </Grid>
                </Border>

                <!-- Lista -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Suppliers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="16,12" Cursor="Hand" Background="Transparent" x:Name="Row">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectSupplierCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding ContactName}" FontSize="12" Foreground="#94A3B8"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Phone}" Foreground="#475569" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Location}" Foreground="#475569" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Row" Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Formulário -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="➕ Novo Fornecedor"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Text" Value="✏️ Editar Fornecedor"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="Empresa *" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="Nome do Contato *" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="Email *" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="Telefone *" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="CNPJ *" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Document, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                <!-- Botões -->
                <Button Content="✅ Salvar Fornecedor" Command="{Binding CreateSupplierCommand}" Style="{StaticResource PrimaryButton}" 
                        HorizontalAlignment="Stretch" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"/>
                
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="💾 Atualizar" Command="{Binding UpdateSupplierCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="🗑️ Excluir" Command="{Binding DeleteSupplierCommand}" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancelar" Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
