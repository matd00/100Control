<UserControl x:Class="Desktop.Features.Suppliers.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:BoolToEditTextConverter x:Key="BoolToEditText"/>
        <Style x:Key="SBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="STb" TargetType="TextBox">
            <Setter Property="Background" Value="#FAFBFD"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,16,0" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="24,20,24,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Fornecedores" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                        <Border Style="{StaticResource BadgePrimary}" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Suppliers.Count}" FontSize="11" Foreground="#6366F1" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource STb}" Width="240" ToolTip="Buscar por Nome, Contato, Email ou Documento"/>
                        <Button Content="✕" Command="{Binding ClearSearchCommand}" Background="#F1F5F9" Foreground="#475569" Style="{StaticResource SBtn}" Padding="8,4" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Background="#FAFBFD" BorderBrush="#F1F5F9" BorderThickness="0,1" Padding="24,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="EMPRESA / CONTATO" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="TELEFONE" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Grid.Column="2" Text="CIDADE" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Suppliers}" Padding="8,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="16,11" Cursor="Hand" Background="Transparent" x:Name="Row" CornerRadius="6">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectSupplierCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding ContactName}" FontSize="12" Foreground="#94A3B8"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Phone}" Foreground="{StaticResource StrongMutedTextBrush}" VerticalAlignment="Center" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Location}" Foreground="{StaticResource StrongMutedTextBrush}" VerticalAlignment="Center" FontSize="13"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Row" Property="Background" Value="#FAFBFD"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource CardContainer}">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Novo Fornecedor"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Text" Value="Editar Fornecedor"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="Empresa *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource STb}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="Nome do Contato *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource STb}" Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="Email *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource STb}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="Telefone *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource STb}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="CNPJ *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource STb}" Text="{Binding Document, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18"/>
                <Button Content="Salvar Fornecedor" Command="{Binding CreateSupplierCommand}" Background="#6366F1" Style="{StaticResource SBtn}" HorizontalAlignment="Stretch" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"/>
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="Atualizar" Command="{Binding UpdateSupplierCommand}" Background="#6366F1" Style="{StaticResource SBtn}" Margin="0,0,8,0"/>
                    <Button Content="Excluir" Command="{Binding DeleteSupplierCommand}" Background="#EF4444" Style="{StaticResource SBtn}" Margin="0,0,8,0"/>
                    <Button Content="Cancelar" Command="{Binding ClearFormCommand}" Background="#F1F5F9" Foreground="#475569" Style="{StaticResource SBtn}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
