<UserControl x:Class="Desktop.Features.Kits.KitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <Style x:Key="KBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KTb" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,16,0" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Kits de Produtos" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                        <Border Style="{StaticResource BadgePrimary}" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Kits.Count}" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource KTb}" Width="240" ToolTip="Buscar por Nome ou Descrição"/>
                        <Button Content="✕" Command="{Binding ClearSearchCommand}" Background="{DynamicResource BorderSubtleBrush}" Foreground="{DynamicResource StrongMutedTextBrush}" Style="{StaticResource KBtn}" Padding="8,4" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Kits}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="16" Margin="0,0,0,10" Cursor="Hand" x:Name="Card" BorderThickness="1" BorderBrush="{DynamicResource PrimaryLightBrush}" Background="{DynamicResource BackgroundBrush}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectKitCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12.5" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Style="{StaticResource BadgeInfo}" Padding="6,3" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding ItemCountText}" FontSize="10.5" Foreground="{DynamicResource InfoBrush}" FontWeight="Medium"/>
                                                </Border>
                                                <Border Style="{StaticResource BadgeSuccess}" Padding="6,3">
                                                    <TextBlock Text="Ativo" FontSize="10.5" Foreground="{DynamicResource SuccessBrush}" FontWeight="Medium"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding PriceFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Card" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                        <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource CardContainer}">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Novo Kit"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Text" Value="Editar Kit"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="Nome *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource KTb}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="Descrição" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource KTb}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>
                <TextBlock Text="Preço *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource KTb}" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18"/>
                <Button Content="Salvar Kit" Command="{Binding CreateKitCommand}" Background="{DynamicResource PrimaryBrush}" Style="{StaticResource KBtn}" HorizontalAlignment="Stretch" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"/>
                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Content="Atualizar" Command="{Binding UpdateKitCommand}" Background="{DynamicResource PrimaryBrush}" Style="{StaticResource KBtn}" Margin="0,0,8,0"/>
                        <Button Content="Excluir" Command="{Binding DeleteKitCommand}" Background="{DynamicResource DangerBrush}" Style="{StaticResource KBtn}" Margin="0,0,8,0"/>
                        <Button Content="Cancelar" Command="{Binding ClearFormCommand}" Background="{DynamicResource BorderSubtleBrush}" Foreground="{DynamicResource StrongMutedTextBrush}" Style="{StaticResource KBtn}"/>
                    </StackPanel>
                    <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="10" Padding="14" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Adicionar Produto" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AvailableProducts}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" Margin="0,0,0,8" Padding="8" FontSize="13"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ProductQuantity}" Padding="8" Margin="0,0,8,0" FontSize="13"/>
                                <Button Grid.Column="1" Content="+ Add" Command="{Binding AddProductToKitCommand}" Background="{DynamicResource SuccessBrush}" Style="{StaticResource KBtn}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
