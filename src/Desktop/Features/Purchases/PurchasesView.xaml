<UserControl x:Class="Desktop.Features.Purchases.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <Style x:Key="PBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,16,0" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Compras" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <Border Style="{StaticResource BadgePrimary}" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Purchases.Count}" FontSize="11" Foreground="#6366F1" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Purchases}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="16" Margin="0,0,0,10" Cursor="Hand" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                            <Setter Property="BorderBrush" Value="#C7D2FE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Pendente">
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                    <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Recebido">
                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                    <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Cancelado">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                    <Setter Property="BorderBrush" Value="#FECACA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectPurchaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Id, StringFormat='#C{0:N8}'}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                <Border Background="#6366F1" CornerRadius="5" Padding="6,2" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding TypeText}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border CornerRadius="5" Padding="6,2" Margin="4,0,0,0" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#059669" FontWeight="Medium"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ItemCount, StringFormat='{}{0} item(s)'}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding DateFormatted, Mode=OneWay}" FontSize="11" Foreground="#94A3B8"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalFormatted, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource CardContainer}">
            <StackPanel>
                <TextBlock Text="Nova Compra" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18"/>
                <TextBlock Text="Fornecedor *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="0,0,0,12" Padding="10" FontSize="13"/>
                <TextBlock Text="Tipo" FontSize="12" FontWeight="Medium" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding PurchaseTypes}" SelectedItem="{Binding PurchaseType}" Margin="0,0,0,16" Padding="10" FontSize="13"/>
                <Button Content="Criar Compra" Command="{Binding CreatePurchaseCommand}" Background="#6366F1" Style="{StaticResource PBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,20"/>
                <Border Background="#FAFBFD" CornerRadius="10" Padding="14" Visibility="{Binding SelectedPurchase, Converter={StaticResource NullToVisibility}}" Margin="0,0,0,16" BorderBrush="#F1F5F9" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="COMPRA SELECIONADA" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SelectedPurchase.TotalFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,4,0,10"/>
                        <TextBlock Text="Adicionar Item" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource StrongMutedTextBrush}" Margin="0,8,0,6"/>
                        <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" Margin="0,0,0,8" Padding="8" FontSize="13"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Quantity}" Padding="8" Margin="0,0,4,0" FontSize="13"/>
                            <TextBox Grid.Column="1" Text="{Binding Cost}" Padding="8" Margin="4,0,0,0" FontSize="13"/>
                        </Grid>
                        <Button Content="+ Adicionar Item" Command="{Binding AddItemToPurchaseCommand}" Background="#22C55E" Style="{StaticResource PBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Recebido" Command="{Binding MarkAsReceivedCommand}" Background="#10B981" Style="{StaticResource PBtn}" Margin="0,0,8,0"/>
                            <Button Content="Cancelar" Command="{Binding CancelPurchaseCommand}" Background="#EF4444" Style="{StaticResource PBtn}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
