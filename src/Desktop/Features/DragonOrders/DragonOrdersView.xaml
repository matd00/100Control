<UserControl x:Class="Desktop.Features.DragonOrders.DragonOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Infrastructure.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- METRICS -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,10,0" Padding="18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource DangerLightBrush}" CornerRadius="6" Padding="5" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="CashMinus" Width="14" Height="14" Foreground="{DynamicResource DangerBrush}" />
                        </Border>
                        <TextBlock Text="A Receber" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalReceivable, StringFormat='R$ {0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardContainer}" Margin="0,0,10,0" Padding="18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="6" Padding="5" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="Factory" Width="14" Height="14" Foreground="{DynamicResource WarningBrush}" />
                        </Border>
                        <TextBlock Text="Dívida Fábrica" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalFactoryDebt, StringFormat='R$ {0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardContainer}" Margin="0,0,10,0" Padding="18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="6" Padding="5" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="CashCheck" Width="14" Height="14" Foreground="{DynamicResource SuccessBrush}" />
                        </Border>
                        <TextBlock Text="Recebido (Mês)" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalReceivedMonth, StringFormat='R$ {0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardContainer}" Padding="18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="6" Padding="5" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="GiftOutline" Width="14" Height="14" Foreground="{DynamicResource PrimaryBrush}" />
                        </Border>
                        <TextBlock Text="Cashback Gerado" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalCashback, StringFormat='R$ {0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- ORDER LIST -->
            <Border Grid.Column="0" Style="{StaticResource CardContainer}" Margin="0,0,14,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,18,20,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pedidos Dragon" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                            <Border Style="{StaticResource BadgePrimary}" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalOrdersCount}" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Command="{Binding RefreshCommand}" Style="{StaticResource GhostButton}" Width="32" Height="32" Padding="0" Margin="8,0,0,0" ToolTip="Atualizar">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" />
                            </Button>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource PlaceholderBrush}" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <ComboBox SelectedItem="{Binding StatusFilter}" Margin="0,0,8,0" Style="{StaticResource ModernComboBox}" MinWidth="140" materialDesign:HintAssist.Hint="Status" RenderTransformOrigin="0.721,0.518" SelectionChanged="ComboBox_SelectionChanged">
                                <ComboBoxItem Content="Todos" IsSelected="True" />
                                <ComboBoxItem Content="Pendentes" />
                                <ComboBoxItem Content="Pagos" />
                                <ComboBoxItem Content="Fábrica Pendente" />
                                <ComboBoxItem Content="Meus Pedidos" />
                            </ComboBox>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Width="200" materialDesign:HintAssist.Hint="Buscar cliente..." />
                        </StackPanel>
                    </Grid>
                    <!-- Column Mini-Header -->
                    <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1" Padding="24,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CLIENTE / STATUS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="1" Text="VALOR" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredOrders}" Padding="8,0,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="16" Margin="0,0,0,8" Cursor="Hand" x:Name="Card" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFullyPaid}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelado">
                                                        <Setter Property="Background" Value="{DynamicResource DangerLightBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectOrderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="14" />
                                                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="5" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="White" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border CornerRadius="5" Padding="6,2" Margin="4,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsClubeDragon, Converter={StaticResource BoolToVisibility}}">
                                                        <Border.Background><SolidColorBrush Color="#8B5CF6" /></Border.Background>
                                                        <TextBlock Text="CLUBE" FontSize="9" Foreground="White" FontWeight="Bold" />
                                                    </Border>
                                                    <Border CornerRadius="5" Padding="6,2" Margin="4,0,0,0" Background="{DynamicResource WarningLightBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" VerticalAlignment="Center" Visibility="{Binding IsOwnOrder, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="MEU" FontSize="9" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} itens'}" FontSize="11" Foreground="{DynamicResource PlaceholderBrush}" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy'}" FontSize="11" Foreground="{DynamicResource PlaceholderBrush}" Margin="0,0,8,0" />
                                                    <Border CornerRadius="4" Padding="5,1" Margin="0" Visibility="{Binding IsFactoryPaid, Converter={StaticResource BoolToVisibility}}">
                                                        <Border.Background><SolidColorBrush Color="{DynamicResource SuccessLightColor}" /></Border.Background>
                                                        <TextBlock Text="Fábrica Paga" FontSize="10" Foreground="{DynamicResource SuccessBrush}" FontWeight="Medium" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding TotalAmount, StringFormat='R$ {0:N2}'}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Right" />
                                                <TextBlock HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Margin="0,3,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding RemainingBalance, StringFormat='Falta: R$ {0:N2}'}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFullyPaid}" Value="True">
                                                                    <Setter Property="Text" Value="QUITADO" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT PANEL -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- NEW ORDER FORM -->
                    <Border Style="{StaticResource CardContainer}" Margin="0,0,0,12" Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Novo Pedido Dragon" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16" />
                            <CheckBox Content="Meu pedido próprio" IsChecked="{Binding IsOwnOrder}" Margin="0,0,0,12" FontSize="13" />

                            <!-- Customer Search -->
                            <TextBlock Text="CLIENTE" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                                     materialDesign:HintAssist.Hint="Buscar por nome, telefone, email ou CPF..." />
                            <ItemsControl ItemsSource="{Binding FilteredCustomers}" MaxHeight="160" Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,7" Cursor="Hand" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" x:Name="CustRow">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5" Foreground="{DynamicResource TextBrush}" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource PlaceholderBrush}"><Run Text="{Binding Phone, Mode=OneWay}" /> — <Run Text="{Binding Email, Mode=OneWay}" /></TextBlock>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CustRow" Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                            </Trigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Selected customer badge -->
                            <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,10" Visibility="{Binding SelectedCustomer, Converter={StaticResource NullToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="{DynamicResource PrimaryBrush}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" FontSize="13" />
                                </StackPanel>
                            </Border>
                            <Button Content="+ Cadastrar Novo Cliente" Command="{Binding GoToCustomersCommand}" Style="{StaticResource GhostButton}" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left" Padding="0,6" FontSize="12" Margin="0,0,0,12" />

                            <CheckBox Content="Clube Dragon (cashback)" IsChecked="{Binding IsClubeDragon}" Margin="0,0,0,10" FontSize="13" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ShippingCost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"
                                     materialDesign:HintAssist.Hint="Frete Fábrica (R$)" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding OrderNotes, UpdateSourceTrigger=PropertyChanged}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"
                                     materialDesign:HintAssist.Hint="Observações" />
                            <Button Content="CRIAR PEDIDO" Command="{Binding CreateOrderCommand}" Style="{StaticResource ModernButton}" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <!-- SELECTED ORDER DETAILS -->
                    <StackPanel Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibility}}">
                        <!-- Header -->
                        <Border Style="{StaticResource CardContainer}" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{Binding SelectedOrder.CustomerName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                                    <Button Command="{Binding ClearFormCommand}" Style="{StaticResource GhostButton}" Padding="6" HorizontalAlignment="Right" Width="32" Height="32" ToolTip="Fechar detalhes">
                                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                                    </Button>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
                                    <Border CornerRadius="5" Padding="8,3" Margin="0,0,6,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Entregue">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Cancelado">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="EnviadoPelaFabrica">
                                                        <Setter Property="Background" Value="{DynamicResource InfoBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding SelectedOrder.Status}" FontSize="10" Foreground="White" FontWeight="SemiBold" />
                                    </Border>
                                    <Border CornerRadius="5" Padding="8,3" Visibility="{Binding SelectedOrder.IsClubeDragon, Converter={StaticResource BoolToVisibility}}">
                                        <Border.Background><SolidColorBrush Color="#8B5CF6" /></Border.Background>
                                        <TextBlock Text="CLUBE DRAGON" FontSize="10" Foreground="White" FontWeight="SemiBold" />
                                    </Border>
                                    <Border CornerRadius="5" Padding="8,3" Visibility="{Binding SelectedOrder.IsFactoryPaid, Converter={StaticResource BoolToVisibility}}">
                                        <Border.Background><SolidColorBrush Color="{DynamicResource SuccessLightColor}" /></Border.Background>
                                        <TextBlock Text="FÁBRICA PAGA" FontSize="10" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Total" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedOrder.TotalAmount, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextBrush}" />
                                </Grid>
                                <Grid><TextBlock Text="Custo Fábrica + Frete" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedOrder.TotalCost, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" FontSize="13" /></Grid>
                                <Grid><TextBlock Text="Pago" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedOrder.TotalPaid, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" FontSize="13" /></Grid>
                                <Grid><TextBlock Text="Cashback" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedOrder.CashbackAmount, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#8B5CF6" FontSize="13" /></Grid>
                                <Border Background="{DynamicResource DangerLightBrush}" CornerRadius="8" Padding="12,8" Margin="0,8,0,0">
                                    <Grid><TextBlock Text="SALDO DEVEDOR" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" FontSize="11" />
                                        <TextBlock Text="{Binding SelectedOrder.RemainingBalance, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" FontSize="16" /></Grid>
                                </Border>
                                <!-- Status Actions (conditional) -->
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="⚡ AÇÕES" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                    <WrapPanel>
                                        <Button Content="✅ Confirmar" Command="{Binding ConfirmOrderCommand}" Style="{StaticResource ModernButton}" Margin="0,0,6,6" Padding="14,0" Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVisibility}}" />
                                        <Button Content="🚚 Enviado" Command="{Binding MarkSentCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource InfoBrush}" Margin="0,0,6,6" Padding="14,0" Visibility="{Binding CanMarkSent, Converter={StaticResource BoolToVisibility}}" />
                                        <Button Content="📦 Entregue" Command="{Binding MarkDeliveredCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Margin="0,0,6,6" Padding="14,0" Visibility="{Binding CanMarkDelivered, Converter={StaticResource BoolToVisibility}}" />
                                        <Button Content="{Binding SelectedOrder.IsFactoryPaid, Converter={x:Static converters:BoolToFactoryPaidConverter.Instance}}" Command="{Binding MarkFactoryPaidCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource WarningBrush}" Margin="0,0,6,6" Padding="14,0" Visibility="{Binding CanMarkFactoryPaid, Converter={StaticResource BoolToVisibility}}" />
                                        <Button Content="Cancelar" Command="{Binding CancelOrderCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource DangerBrush}" Margin="0,0,6,6" Padding="14,0" Visibility="{Binding CanCancelOrder, Converter={StaticResource BoolToVisibility}}" />
                                    </WrapPanel>
                                    <Button Content="🗑️ Excluir Pedido" Command="{Binding DeleteOrderCommand}" Style="{StaticResource GhostButton}" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Left" Padding="0,6" FontSize="11" Margin="0,4,0,0" Visibility="{Binding CanDeleteOrder, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ADD ITEM -->
                        <Border Style="{StaticResource CardContainer}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ADICIONAR ITEM" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,12" />
                                <ComboBox ItemsSource="{Binding BoxTypes}" SelectedItem="{Binding ItemBoxType}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,8"
                                          materialDesign:HintAssist.Hint="Tipo da Caixa" />
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ItemDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                                         materialDesign:HintAssist.Hint="Descrição (opcional — auto da caixa)" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ItemQuantity, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" Margin="0,0,4,0"
                                             materialDesign:HintAssist.Hint="Qtd" />
                                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding ItemUnitCost, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"
                                             materialDesign:HintAssist.Hint="Custo" />
                                    <TextBox Grid.Column="2" Style="{StaticResource ModernTextBox}" Text="{Binding ItemUnitPrice, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"
                                             materialDesign:HintAssist.Hint="Preço" />
                                </Grid>
                                <Button Content="+ Adicionar Item" Command="{Binding AddItemCommand}" Style="{StaticResource ModernButton}" HorizontalAlignment="Stretch" />
                                <!-- Items List -->
                                <ItemsControl ItemsSource="{Binding SelectedOrderItems}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding BoxType}" FontSize="10" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0}x'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontWeight="Medium" FontSize="12" Margin="0,3,0,0" />
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource PlaceholderBrush}"><Run Text="Custo: R$ " /><Run Text="{Binding UnitCost, StringFormat='{}{0:N2}', Mode=OneWay}" /> — <Run Text="Venda: R$ " /><Run Text="{Binding UnitPrice, StringFormat='{}{0:N2}', Mode=OneWay}" /></TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding SubtotalPrice, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13" Margin="0,0,6,0" />
                                                    <Button Grid.Column="2" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" ToolTip="Remover item">
                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="{StaticResource DangerBrush}" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- PAYMENTS -->
                        <Border Style="{StaticResource CardContainer}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="REGISTRAR PAGAMENTO" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,12" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="130" /></Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" Margin="0,0,6,0"
                                             materialDesign:HintAssist.Hint="Valor (R$)" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding PaymentMethod}" Style="{StaticResource ModernComboBox}" Margin="6,0,0,0"
                                              materialDesign:HintAssist.Hint="Método" />
                                </Grid>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding PaymentNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"
                                         materialDesign:HintAssist.Hint="Obs (ex: parcela maio)" />
                                <Button Content="REGISTRAR PAGAMENTO" Command="{Binding AddPaymentCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" HorizontalAlignment="Stretch" />
                                <!-- Payment History -->
                                <ItemsControl ItemsSource="{Binding SelectedOrderPayments}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}"><Run Text="{Binding Method, Mode=OneWay}" /> — <Run Text="{Binding PaidAt, StringFormat='dd/MM/yyyy', Mode=OneWay}" /></TextBlock>
                                                        <TextBlock Text="{Binding Notes}" FontSize="11" Foreground="{DynamicResource PlaceholderBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" FontSize="14" Margin="0,0,6,0" />
                                                    <Button Grid.Column="2" Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" ToolTip="Remover pagamento">
                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="{StaticResource DangerBrush}" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>