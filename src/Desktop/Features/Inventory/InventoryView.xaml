<UserControl x:Class="Desktop.Features.Inventory.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:domain="clr-namespace:Domain.Entities;assembly=Domain"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="IBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ITb" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardContainer}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Atualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource BorderSubtleBrush}" Foreground="{DynamicResource StrongMutedTextBrush}" Style="{StaticResource IBtn}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" FontWeight="Medium" FontSize="13"/>
                </StackPanel>
                <TextBox Grid.Column="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ITb}" Margin="12,0,12,0" Width="240" ToolTip="Buscar por produto ou referência"/>
                <ComboBox Grid.Column="3" SelectedItem="{Binding TypeFilter}" MinWidth="140" VerticalAlignment="Center" FontSize="13" Padding="10,8">
                    <ComboBoxItem Content="Todos os Tipos"/>
                    <domain:InventoryMovementType>Purchase</domain:InventoryMovementType>
                    <domain:InventoryMovementType>Sale</domain:InventoryMovementType>
                    <domain:InventoryMovementType>Adjustment</domain:InventoryMovementType>
                    <domain:InventoryMovementType>KitUsage</domain:InventoryMovementType>
                    <domain:InventoryMovementType>Return</domain:InventoryMovementType>
                </ComboBox>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Padding="0">
            <DataGrid ItemsSource="{Binding Movements}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Background="{DynamicResource SurfaceBrush}" RowHeight="44" BorderThickness="0" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderSubtleBrush}" IsReadOnly="True" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding CreatedAtFormatted, Mode=OneWay}" Width="140"/>
                    <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTemplateColumn Header="Tipo" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TypeDisplay}" VerticalAlignment="Center" Foreground="{DynamicResource StrongMutedTextBrush}" FontWeight="Medium"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Qtd" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding QuantityDisplay}" Foreground="{Binding QuantityColor}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Referência" Binding="{Binding Reference}" Width="200"/>
                    <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
