<Window x:Class="Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:dash="clr-namespace:Desktop.Features.Dashboard"
        Title="PaintballManager" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0,26,26,0"/>
            <Setter Property="Margin" Value="0,2,16,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2D3748"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog" SnackbarMessageQueue="{Binding ElementName=MainSnackbar, Path=MessageQueue}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#0F172A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="24,48,24,40" Orientation="Horizontal">
                        <Border Background="#4F46E5" CornerRadius="8" Width="40" Height="40">
                            <materialDesign:PackIcon Kind="Target" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="100Control" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Admin Dashboard" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="MENU PRINCIPAL" FontSize="11" Foreground="#475569" Margin="24,0,0,12" FontWeight="Bold" Opacity="0.8" />
                            <Button x:Name="BtnDashboard" Style="{StaticResource MenuButtonActive}" Click="Dashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="20" Height="20"/>
                                    <TextBlock Text="Dashboard" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnProducts" Style="{StaticResource MenuButton}" Click="Products_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20"/>
                                    <TextBlock Text="Produtos" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnKits" Style="{StaticResource MenuButton}" Click="Kits_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Tools" Width="20" Height="20"/>
                                    <TextBlock Text="Kits de Peças" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnOrders" Style="{StaticResource MenuButton}" Click="Orders_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CartOutline" Width="20" Height="20"/>
                                    <TextBlock Text="Pedidos" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCustomers" Style="{StaticResource MenuButton}" Click="Customers_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroupOutline" Width="20" Height="20"/>
                                    <TextBlock Text="Clientes" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="OPERAÇÕES" FontSize="11" Foreground="#475569" Margin="24,30,0,12" FontWeight="Bold" Opacity="0.8" />
                            <Button x:Name="BtnSuppliers" Style="{StaticResource MenuButton}" Click="Suppliers_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Factory" Width="20" Height="20"/>
                                    <TextBlock Text="Fornecedores" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnPurchases" Style="{StaticResource MenuButton}" Click="Purchases_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShoppingOutline" Width="20" Height="20"/>
                                    <TextBlock Text="Compras" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnInventory" Style="{StaticResource MenuButton}" Click="Inventory_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20"/>
                                    <TextBlock Text="Estoque" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnShipments" Style="{StaticResource MenuButton}" Click="Shipments_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TruckDeliveryOutline" Width="20" Height="20"/>
                                    <TextBlock Text="Envios" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="INTEGRAÇÕES" FontSize="11" Foreground="#475569" Margin="24,30,0,12" FontWeight="Bold" Opacity="0.8" />
                            <Button x:Name="BtnMercadoLivre" Style="{StaticResource MenuButton}" Click="MercadoLivre_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="StorefrontOutline" Width="20" Height="20" Foreground="#FFE600"/>
                                    <TextBlock Text="Mercado Livre" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnShopee" Style="{StaticResource MenuButton}" Click="Shopee_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShoppingOutline" Width="20" Height="20" Foreground="#EE4D2D"/>
                                    <TextBlock Text="Shopee" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#0c1221" Padding="24,24">
                        <StackPanel>
                            <TextBlock Text="CONTROL SYSTEM" FontSize="10" Foreground="#475569" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Border Width="8" Height="8" CornerRadius="4" Background="#10B981" VerticalAlignment="Center"/>
                                <TextBlock Text="v1.1.0 Online" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,0" FontWeight="Medium"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="40,24" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock x:Name="PageSubtitle" Text="Visão geral do sistema" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <materialDesign:Badged Badge="3" BadgeBackground="{StaticResource DangerBrush}" Margin="0,0,24,0">
                                <Button Style="{StaticResource MaterialDesignIconButton}" Foreground="#64748B">
                                    <materialDesign:PackIcon Kind="BellOutline" Width="24" Height="24"/>
                                </Button>
                            </materialDesign:Badged>
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="14,10" BorderBrush="#F1F5F9" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarMonthOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#4F46E5"/>
                                    <TextBlock x:Name="TxtDate" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#475569"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F8FAFC">
                    <Grid>
                        <Border Padding="40,32">
                            <Grid>
                                <!-- Dynamic Content Container -->
                                <StackPanel x:Name="DynamicContent"/>

                                <!-- Other static contents (legacy) -->
                                <Grid x:Name="MercadoLivreContent" Visibility="Collapsed"/>
                                <Grid x:Name="ShopeeContent" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        
                        <!-- Global Snackbar -->
                        <materialDesign:Snackbar x:Name="MainSnackbar" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
