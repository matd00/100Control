<Window x:Class="Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaintballManager - Sistema de Gestão" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0,8,8,0" Margin="0,2,12,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1E293B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,30,24,35">
                    <TextBlock Text="PAINTBALL" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                    <TextBlock Text="MANAGER" FontSize="22" FontWeight="Light" Foreground="White" Margin="0,-2,0,0"/>
                    <TextBlock Text="Sistema de Gestão" FontSize="11" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="PRINCIPAL" FontSize="10" Foreground="#64748B" Margin="24,0,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnDashboard" Content="📊 Dashboard" Style="{StaticResource MenuButtonActive}" Click="Dashboard_Click"/>
                        <Button x:Name="BtnProducts" Content="📦 Produtos" Style="{StaticResource MenuButton}" Click="Products_Click"/>
                        <Button x:Name="BtnOrders" Content="🛒 Pedidos" Style="{StaticResource MenuButton}" Click="Orders_Click"/>
                        <Button x:Name="BtnCustomers" Content="👥 Clientes" Style="{StaticResource MenuButton}" Click="Customers_Click"/>
                        
                        <TextBlock Text="OPERAÇÕES" FontSize="10" Foreground="#64748B" Margin="24,30,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnSuppliers" Content="🏭 Fornecedores" Style="{StaticResource MenuButton}" Click="Suppliers_Click"/>
                        <Button x:Name="BtnPurchases" Content="💰 Compras" Style="{StaticResource MenuButton}" Click="Purchases_Click"/>
                        <Button x:Name="BtnKits" Content="🎯 Kits" Style="{StaticResource MenuButton}" Click="Kits_Click"/>
                        <Button x:Name="BtnInventory" Content="📦 Estoque" Style="{StaticResource MenuButton}" Click="Inventory_Click"/>
                        <Button x:Name="BtnShipments" Content="🚚 Envios" Style="{StaticResource MenuButton}" Click="Shipments_Click"/>
                        
                        <TextBlock Text="INTEGRAÇÕES" FontSize="10" Foreground="#64748B" Margin="24,30,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnMercadoLivre" Content="🟡 Mercado Livre" Style="{StaticResource MenuButton}" Click="MercadoLivre_Click"/>
                        <Button x:Name="BtnShopee" Content="🟠 Shopee" Style="{StaticResource MenuButton}" Click="Shopee_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="24,18">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="v1.0.0" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="SQLite + EF Core" FontSize="10" Foreground="#475569" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Ellipse Width="10" Height="10" Fill="#22C55E" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="30,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock x:Name="PageSubtitle" Text="Visão geral do sistema" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Background="#F1F5F9" CornerRadius="8" Padding="12,8" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtDate" Foreground="#475569" FontSize="13"/>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
                <Grid>
                    <!-- Dashboard Content -->
                    <Grid x:Name="DashboardContent" Visibility="Visible">
                        <StackPanel>
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="Fábrica: Pedidos Pendentes" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding FactoryPendingOrders}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Fábrica: Receita do Mês" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding FactoryMonthRevenue, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#22C55E" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Vendas Hoje" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding TodaysSales, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Pedidos Pendentes" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding PendingOrders}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Estoque Baixo" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding LowStockProducts}" FontSize="28" FontWeight="Bold" Foreground="#EF4444" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Lucro do Mês" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding TodaysProfit, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#22C55E" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Ações Rápidas" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>
                                    <WrapPanel>
                                        <Button Content="+ Novo Produto" Style="{StaticResource PrimaryButton}" Margin="0,0,12,12" Click="Products_Click"/>
                                        <Button Content="+ Novo Pedido" Style="{StaticResource SuccessButton}" Margin="0,0,12,12" Click="Orders_Click"/>
                                        <Button Content="+ Novo Cliente" Style="{StaticResource PrimaryButton}" Margin="0,0,12,12" Click="Customers_Click"/>
                                        <Button Content="+ Novo Kit" Style="{StaticResource PrimaryButton}" Margin="0,0,12,12" Click="Kits_Click" Background="#8B5CF6"/>
                                        <Button Content="+ Novo Fornecedor" Style="{StaticResource PrimaryButton}" Margin="0,0,12,12" Click="Suppliers_Click" Background="#8B5CF6"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Dynamic Content Container for Views -->
                    <StackPanel x:Name="DynamicContent"/>

                    <!-- Mercado Livre -->
                    <Grid x:Name="MercadoLivreContent" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="🟡 Mercado Livre" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>
                                <TextBlock Text="Integração com o Mercado Livre. Configure nas opções." Foreground="#64748B"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Shopee -->
                    <Grid x:Name="ShopeeContent" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="🟠 Shopee" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>
                                <TextBlock Text="Integração com a Shopee. Configure nas opções." Foreground="#64748B"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
