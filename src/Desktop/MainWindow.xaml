<Window x:Class="Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:dash="clr-namespace:Desktop.Features.Dashboard"
        Title="PaintballManager" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0,20,20,0"/>
            <Setter Property="Margin" Value="0,2,16,2"/>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog" SnackbarMessageQueue="{Binding ElementName=MainSnackbar, Path=MessageQueue}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#1E293B" Effect="{StaticResource MaterialDesignShadowDepth3}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="24,40,24,40" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Target" Foreground="#3B82F6" Width="32" Height="32" VerticalAlignment="Center"/>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="100Control" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Management System" FontSize="10" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="MAIN MENU" FontSize="11" Foreground="#475569" Margin="24,0,0,12" FontWeight="Bold" Opacity="0.8"/>
                            <Button x:Name="BtnDashboard" Style="{StaticResource MenuButtonActive}" Click="Dashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20"/>
                                    <TextBlock Text="Dashboard" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnProducts" Style="{StaticResource MenuButton}" Click="Products_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20"/>
                                    <TextBlock Text="Products" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnKits" Style="{StaticResource MenuButton}" Click="Kits_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Tools" Width="20" Height="20"/>
                                    <TextBlock Text="Kits" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnOrders" Style="{StaticResource MenuButton}" Click="Orders_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cart" Width="20" Height="20"/>
                                    <TextBlock Text="Orders" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCustomers" Style="{StaticResource MenuButton}" Click="Customers_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20"/>
                                    <TextBlock Text="Customers" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="OPERATIONS" FontSize="11" Foreground="#475569" Margin="24,30,0,12" FontWeight="Bold" Opacity="0.8"/>
                            <Button x:Name="BtnSuppliers" Style="{StaticResource MenuButton}" Click="Suppliers_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Factory" Width="20" Height="20"/>
                                    <TextBlock Text="Suppliers" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnPurchases" Style="{StaticResource MenuButton}" Click="Purchases_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShoppingBasket" Width="20" Height="20"/>
                                    <TextBlock Text="Purchases" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnInventory" Style="{StaticResource MenuButton}" Click="Inventory_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20"/>
                                    <TextBlock Text="Inventory" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnShipments" Style="{StaticResource MenuButton}" Click="Shipments_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TruckDelivery" Width="20" Height="20"/>
                                    <TextBlock Text="Shipments" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="INTEGRATIONS" FontSize="11" Foreground="#475569" Margin="24,30,0,12" FontWeight="Bold" Opacity="0.8"/>
                            <Button x:Name="BtnMercadoLivre" Style="{StaticResource MenuButton}" Click="MercadoLivre_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Storefront" Width="20" Height="20" Foreground="#FFE600"/>
                                    <TextBlock Text="Mercado Livre" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnShopee" Style="{StaticResource MenuButton}" Click="Shopee_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Shopping" Width="20" Height="20" Foreground="#EE4D2D"/>
                                    <TextBlock Text="Shopee" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#1a222f" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="v1.1.0" FontSize="11" Foreground="#64748B" FontWeight="Bold"/>
                            <TextBlock Text="Connected" FontSize="10" Foreground="#10B981" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="32,24" Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="PageTitle" Text="Dashboard" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold"/>
                            <TextBlock x:Name="PageSubtitle" Text="General system overview" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <materialDesign:Badged Badge="3" BadgeBackground="{StaticResource DangerBrush}" Margin="0,0,24,0">
                                <Button Style="{StaticResource MaterialDesignIconButton}">
                                    <materialDesign:PackIcon Kind="Bell" Width="24" Height="24"/>
                                </Button>
                            </materialDesign:Badged>
                            <Border Background="#F1F5F9" CornerRadius="8" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Calendar" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.6"/>
                                    <TextBlock x:Name="TxtDate" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Border Padding="32">
                            <Grid>
                                <!-- Dynamic Content Container -->
                                <StackPanel x:Name="DynamicContent"/>

                                <!-- Other static contents (legacy) -->
                                <Grid x:Name="MercadoLivreContent" Visibility="Collapsed"/>
                                <Grid x:Name="ShopeeContent" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        
                        <!-- Global Snackbar -->
                        <materialDesign:Snackbar x:Name="MainSnackbar" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
