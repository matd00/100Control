<Window x:Class="Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dash="clr-namespace:Desktop.Features.Dashboard"
        Title="PaintballManager - Sistema de Gestão" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0,8,8,0" Margin="0,2,12,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1E293B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,30,24,35">
                    <TextBlock Text="PAINTBALL" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                    <TextBlock Text="MANAGER" FontSize="22" FontWeight="Light" Foreground="White" Margin="0,-2,0,0"/>
                    <TextBlock Text="Sistema de Gestão" FontSize="11" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="PRINCIPAL" FontSize="10" Foreground="#64748B" Margin="24,0,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnDashboard" Content="📊 Dashboard" Style="{StaticResource MenuButtonActive}" Click="Dashboard_Click"/>
                        <Button x:Name="BtnProducts" Content="📦 Produtos" Style="{StaticResource MenuButton}" Click="Products_Click"/>
                        <Button x:Name="BtnOrders" Content="🛒 Pedidos" Style="{StaticResource MenuButton}" Click="Orders_Click"/>
                        <Button x:Name="BtnCustomers" Content="👥 Clientes" Style="{StaticResource MenuButton}" Click="Customers_Click"/>
                        
                        <TextBlock Text="OPERAÇÕES" FontSize="10" Foreground="#64748B" Margin="24,30,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnSuppliers" Content="🏭 Fornecedores" Style="{StaticResource MenuButton}" Click="Suppliers_Click"/>
                        <Button x:Name="BtnPurchases" Content="💰 Compras" Style="{StaticResource MenuButton}" Click="Purchases_Click"/>
                        <Button x:Name="BtnKits" Content="🎯 Kits" Style="{StaticResource MenuButton}" Click="Kits_Click"/>
                        <Button x:Name="BtnInventory" Content="📦 Estoque" Style="{StaticResource MenuButton}" Click="Inventory_Click"/>
                        <Button x:Name="BtnShipments" Content="🚚 Envios" Style="{StaticResource MenuButton}" Click="Shipments_Click"/>
                        
                        <TextBlock Text="INTEGRAÇÕES" FontSize="10" Foreground="#64748B" Margin="24,30,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnMercadoLivre" Content="🟡 Mercado Livre" Style="{StaticResource MenuButton}" Click="MercadoLivre_Click"/>
                        <Button x:Name="BtnShopee" Content="🟠 Shopee" Style="{StaticResource MenuButton}" Click="Shopee_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="24,18">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="v1.0.0" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="SQLite + EF Core" FontSize="10" Foreground="#475569" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Ellipse Width="10" Height="10" Fill="#22C55E" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="30,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock x:Name="PageSubtitle" Text="Visão geral do sistema" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Background="#F1F5F9" CornerRadius="8" Padding="12,8" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtDate" Foreground="#475569" FontSize="13"/>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
                <Grid>
                    <!-- Dashboard Content -->
                    <Grid x:Name="DashboardContent" Visibility="Visible">
                        <StackPanel>
                            <!-- Period Selector & Summary Metrics -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                                <StackPanel>
                                    <Grid Margin="0,0,0,20">
                                        <TextBlock Text="Desempenho de Vendas" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B"/>
                                            <ComboBox SelectedValue="{Binding SelectedPeriod}" Width="150" Padding="8,4">
                                                <dash:DashboardPeriod>Today</dash:DashboardPeriod>
                                                <dash:DashboardPeriod>Last7Days</dash:DashboardPeriod>
                                                <dash:DashboardPeriod>Last30Days</dash:DashboardPeriod>
                                                <dash:DashboardPeriod>Last90Days</dash:DashboardPeriod>
                                                <dash:DashboardPeriod>AllTime</dash:DashboardPeriod>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Faturamento Total" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding TotalRevenue, StringFormat='R$ {0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Lucro Estimado" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding TotalProfit, StringFormat='R$ {0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="#22C55E" Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Total de Pedidos" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding OrderCount}" FontSize="24" FontWeight="Bold" Foreground="#3B82F6" Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="Ticket Médio" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding AverageOrderValue, StringFormat='R$ {0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Operational Status -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="📦 Pedidos Pendentes" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding PendingOrders}" FontSize="26" FontWeight="Bold" Foreground="#F59E0B" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,12,0" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="⚠️ Estoque Baixo" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding LowStockProductsCount}" FontSize="26" FontWeight="Bold" Foreground="#EF4444" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,12,0" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="🏭 Fábrica Pendente" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding FactoryPendingOrders}" FontSize="26" FontWeight="Bold" Foreground="#F59E0B" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="12,0,0,0" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="🏭 Receita Fábrica" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding FactoryPeriodRevenue, StringFormat='R$ {0:N2}'}" FontSize="26" FontWeight="Bold" Foreground="#10B981" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Recent Orders & Top Products -->
                                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                                        <StackPanel>
                                            <TextBlock Text="Pedidos Recentes" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,15"/>
                                            <ItemsControl ItemsSource="{Binding RecentOrders}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding OrderId}" Foreground="#3B82F6" FontWeight="Medium" Width="80"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding CustomerName}" Foreground="#1E293B"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Total, StringFormat='R$ {0:N2}'}" FontWeight="SemiBold" Width="100" TextAlignment="Right" Margin="10,0"/>
                                                                <Border Grid.Column="3" CornerRadius="4" Padding="8,2" Background="#F1F5F9">
                                                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#475569"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Produtos Mais Vendidos" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,15"/>
                                            <ItemsControl ItemsSource="{Binding TopProducts}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding ProductName}" Foreground="#1E293B" FontWeight="Medium"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='{}{0} un.'}" Foreground="#64748B" Width="80" TextAlignment="Right"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Revenue, StringFormat='R$ {0:N2}'}" FontWeight="SemiBold" Width="120" TextAlignment="Right" Margin="10,0"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Side Panels -->
                                <StackPanel Grid.Column="1">
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                                        <StackPanel>
                                            <TextBlock Text="Vendas por Origem" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,15"/>
                                            <ItemsControl ItemsSource="{Binding SalesBySource}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,15">
                                                            <Grid>
                                                                <TextBlock Text="{Binding Source}" Foreground="#475569" FontSize="13"/>
                                                                <TextBlock Text="{Binding Revenue, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"/>
                                                            </Grid>
                                                            <Grid Margin="0,5,0,0">
                                                                <Border Background="#F1F5F9" Height="8" CornerRadius="4">
                                                                    <ProgressBar Value="{Binding Percentage}" Maximum="100" Height="8" Background="Transparent" BorderThickness="0">
                                                                        <ProgressBar.Template>
                                                                            <ControlTemplate TargetType="ProgressBar">
                                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                    <Grid Name="PART_Track">
                                                                                        <Border Name="PART_Indicator" Background="#3B82F6" CornerRadius="4" HorizontalAlignment="Left"/>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </ProgressBar.Template>
                                                                    </ProgressBar>
                                                                </Border>
                                                            </Grid>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Ações Rápidas" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>
                                            <Button Content="+ Novo Produto" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Click="Products_Click"/>
                                            <Button Content="+ Novo Pedido" Style="{StaticResource SuccessButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Click="Orders_Click"/>
                                            <Button Content="+ Novo Cliente" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Click="Customers_Click" Background="#6366F1"/>
                                            <Button Content="+ Novo Kit" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Click="Kits_Click" Background="#8B5CF6"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Dynamic Content Container for Views -->
                    <StackPanel x:Name="DynamicContent"/>

                    <!-- Mercado Livre -->
                    <Grid x:Name="MercadoLivreContent" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="🟡 Mercado Livre" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>
                                <TextBlock Text="Integração com o Mercado Livre. Configure nas opções." Foreground="#64748B"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Shopee -->
                    <Grid x:Name="ShopeeContent" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="🟠 Shopee" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>
                                <TextBlock Text="Integração com a Shopee. Configure nas opções." Foreground="#64748B"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
