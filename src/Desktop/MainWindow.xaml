<Window x:Class="Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaintballManager - Sistema de Gestao" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- Menu Button -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0,8,8,0" Margin="0,2,12,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Card -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Opacity="0.08" ShadowDepth="4" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Success Button -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#22C55E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#16A34A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button -->
        <Style x:Key="TabButton" TargetType="Border">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="TabButtonActive" TargetType="Border">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1E293B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="24,30,24,35">
                    <TextBlock Text="PAINTBALL" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                    <TextBlock Text="MANAGER" FontSize="22" FontWeight="Light" Foreground="White" Margin="0,-2,0,0"/>
                    <TextBlock Text="Sistema de Gestao" FontSize="11" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Menu -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="PRINCIPAL" FontSize="10" Foreground="#64748B" Margin="24,0,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnDashboard" Content="Dashboard" Style="{StaticResource MenuButtonActive}" Click="Dashboard_Click"/>
                        <Button x:Name="BtnProducts" Content="Produtos" Style="{StaticResource MenuButton}" Click="Products_Click"/>
                        <Button x:Name="BtnOrders" Content="Pedidos" Style="{StaticResource MenuButton}" Click="Orders_Click"/>
                        <Button x:Name="BtnCustomers" Content="Clientes" Style="{StaticResource MenuButton}" Click="Customers_Click"/>
                        
                        <TextBlock Text="OPERACOES" FontSize="10" Foreground="#64748B" Margin="24,30,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnSuppliers" Content="Fornecedores" Style="{StaticResource MenuButton}" Click="Suppliers_Click"/>
                        <Button x:Name="BtnPurchases" Content="Compras" Style="{StaticResource MenuButton}" Click="Purchases_Click"/>
                        <Button x:Name="BtnKits" Content="Kits" Style="{StaticResource MenuButton}" Click="Kits_Click"/>
                        <Button x:Name="BtnShipments" Content="Envios" Style="{StaticResource MenuButton}" Click="Shipments_Click"/>
                        
                        <TextBlock Text="INTEGRACOES" FontSize="10" Foreground="#64748B" Margin="24,30,0,12" FontWeight="Bold"/>
                        <Button x:Name="BtnMercadoLivre" Content="Mercado Livre" Style="{StaticResource MenuButton}" Click="MercadoLivre_Click"/>
                        <Button x:Name="BtnShopee" Content="Shopee" Style="{StaticResource MenuButton}" Click="Shopee_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="24,18">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="v1.0.0" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="Desenvolvido com C#" FontSize="10" Foreground="#475569" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Ellipse Width="10" Height="10" Fill="#22C55E" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White" Padding="30,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock x:Name="PageSubtitle" Text="Visao geral do sistema" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#F1F5F9" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
                            <TextBlock x:Name="TxtDate" Text="07/03/2026" Foreground="#475569" FontSize="13"/>
                        </Border>
                        <Border Background="#3B82F6" CornerRadius="8" Padding="12,8">
                            <TextBlock Text="Sincronizar" Foreground="White" FontSize="13" Cursor="Hand"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
                <Grid x:Name="ContentContainer">
                    
                    <!-- DASHBOARD -->
                    <Grid x:Name="DashboardContent" Visibility="Visible">
                        <StackPanel>
                            <!-- Stats Row -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Vendas Hoje" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="R$ 12.450,00" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border Background="#DCFCE7" CornerRadius="4" Padding="6,3">
                                                <TextBlock Text="+18%" FontSize="12" Foreground="#16A34A" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text=" vs ontem" Foreground="#94A3B8" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Pedidos Pendentes" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="12" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,10,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border Background="#FEF3C7" CornerRadius="4" Padding="6,3">
                                                <TextBlock Text="5 urgentes" FontSize="12" Foreground="#D97706" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Estoque Baixo" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="8" FontSize="28" FontWeight="Bold" Foreground="#EF4444" Margin="0,10,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border Background="#FEE2E2" CornerRadius="4" Padding="6,3">
                                                <TextBlock Text="Reposicao urgente" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Lucro do Mes" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="R$ 28.350,00" FontSize="28" FontWeight="Bold" Foreground="#22C55E" Margin="0,10,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border Background="#DCFCE7" CornerRadius="4" Padding="6,3">
                                                <TextBlock Text="32% margem" FontSize="12" Foreground="#16A34A" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Content Row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Recent Orders -->
                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,20">
                                            <TextBlock Text="Pedidos Recentes" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock Text="Ver todos" FontSize="13" Foreground="#3B82F6" HorizontalAlignment="Right" Cursor="Hand"/>
                                        </Grid>

                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="#1234 - Marker Planet Eclipse CS2" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                    <TextBlock Text="Mercado Livre - Joao Silva" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="R$ 6.500,00" FontWeight="Bold" Foreground="#1E293B" Margin="20,0" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Background="#FEF3C7" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
                                                    <TextBlock Text="Pendente" FontSize="12" Foreground="#D97706" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="#1233 - Kit Iniciante Completo" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                    <TextBlock Text="Shopee - Maria Santos" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="R$ 1.200,00" FontWeight="Bold" Foreground="#1E293B" Margin="20,0" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Background="#DBEAFE" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
                                                    <TextBlock Text="Processando" FontSize="12" Foreground="#2563EB" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Border Padding="0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="#1232 - Mascara Dye i5 + Thermal Lens" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                    <TextBlock Text="Instagram - Pedro Costa" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="R$ 1.100,00" FontWeight="Bold" Foreground="#1E293B" Margin="20,0" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Background="#DCFCE7" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
                                                    <TextBlock Text="Enviado" FontSize="12" Foreground="#16A34A" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Quick Actions -->
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Acoes Rapidas" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>
                                        <Button Content="+ Novo Produto" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Click="Products_Click"/>
                                        <Button Content="+ Novo Pedido" Style="{StaticResource SuccessButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Click="Orders_Click"/>
                                        <Button Content="+ Registrar Compra" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12" HorizontalAlignment="Stretch" Background="#8B5CF6" Click="Purchases_Click"/>
                                        <Button Content="Sincronizar Mercado Livre" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Background="#F59E0B" Click="MercadoLivre_Click"/>
                                        
                                        <Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Ultima Sincronizacao" FontSize="12" Foreground="#64748B"/>
                                                <TextBlock Text="Hoje, 14:32" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- PRODUTOS -->
                    <Grid x:Name="ProductsContent" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Width="350" HorizontalAlignment="Left" Text="" Tag="Buscar produto por nome ou SKU..."/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Exportar" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                                        <Button Content="+ Novo Produto" Style="{StaticResource PrimaryButton}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Table Header -->
                                <Border Background="#F8FAFC" CornerRadius="8" Padding="20,14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="PRODUTO" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="1" Text="ESTOQUE" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="2" Text="CUSTO" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="3" Text="PRECO" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="4" Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="5" Text="ACOES" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                    </Grid>
                                </Border>

                                <!-- Product Items -->
                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="20,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Marker Planet Eclipse CS2" FontWeight="SemiBold" Foreground="#1E293B" FontSize="14"/>
                                            <TextBlock Text="SKU: MK-PE-CS2-001" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="12 un" Foreground="#1E293B" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Grid.Column="2" Text="R$ 4.500" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Grid.Column="3" Text="R$ 6.500" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center" FontSize="14"/>
                                        <Border Grid.Column="4" Background="#DCFCE7" CornerRadius="6" Padding="10,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="Ativo" FontSize="12" Foreground="#16A34A" FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Editar" Foreground="#3B82F6" FontSize="13" Cursor="Hand" Margin="0,0,12,0"/>
                                            <TextBlock Text="Excluir" Foreground="#EF4444" FontSize="13" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="20,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Mascara Dye i5" FontWeight="SemiBold" Foreground="#1E293B" FontSize="14"/>
                                            <TextBlock Text="SKU: MS-DYE-I5-002" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="3 un" Foreground="#EF4444" FontWeight="Bold" FontSize="14"/>
                                            <Border Background="#FEE2E2" CornerRadius="4" Padding="4,2" Margin="8,0,0,0">
                                                <TextBlock Text="BAIXO" FontSize="9" Foreground="#DC2626" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="R$ 650" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Grid.Column="3" Text="R$ 950" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center" FontSize="14"/>
                                        <Border Grid.Column="4" Background="#FEF3C7" CornerRadius="6" Padding="10,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="Baixo Estoque" FontSize="12" Foreground="#D97706" FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Editar" Foreground="#3B82F6" FontSize="13" Cursor="Hand" Margin="0,0,12,0"/>
                                            <TextBlock Text="Excluir" Foreground="#EF4444" FontSize="13" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="20,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Cilindro HPA Ninja 68ci" FontWeight="SemiBold" Foreground="#1E293B" FontSize="14"/>
                                            <TextBlock Text="SKU: CL-NJ-68-003" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="25 un" Foreground="#1E293B" VerticalAlignment="Center" FontSize="14"/>
