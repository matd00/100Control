<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- DARK THEME — Premium SaaS Color Palette                -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <!-- Primary — Modern Indigo -->
    <Color x:Key="PrimaryColor">#818CF8</Color>
    <Color x:Key="PrimaryHoverColor">#6366F1</Color>
    <Color x:Key="PrimaryLightColor">#312E81</Color>

    <!-- Neutral Palette — Slate scale -->
    <Color x:Key="BackgroundColor">#0F172A</Color>
    <Color x:Key="SurfaceColor">#1E293B</Color>
    <Color x:Key="CardBackgroundColor">#1E293B</Color>
    <Color x:Key="BorderColor">#334155</Color>
    <Color x:Key="BorderSubtleColor">#1E293B</Color>

    <!-- Text Hierarchy -->
    <Color x:Key="TextColor">#F8FAFC</Color>
    <Color x:Key="TextSecondaryColor">#CBD5E1</Color>
    <Color x:Key="MutedTextColor">#94A3B8</Color>
    <Color x:Key="StrongMutedTextColor">#64748B</Color>
    <Color x:Key="PlaceholderColor">#475569</Color>

    <!-- Semantic Colors (Slightly adjusted for dark) -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="SuccessLightColor">#064E3B</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningLightColor">#78350F</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerLightColor">#7F1D1D</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoLightColor">#1E3A8A</Color>

    <!-- Sidebar -->
    <Color x:Key="SidebarBgColor">#020617</Color>
    <Color x:Key="SidebarHoverColor">#0F172A</Color>
    <Color x:Key="SidebarActiveColor">#6366F1</Color>
    <Color x:Key="SidebarTextColor">#94A3B8</Color>
    <Color x:Key="SidebarTextActiveColor">#FFFFFF</Color>
    <Color x:Key="SidebarSectionColor">#334155</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="StrongMutedTextBrush" Color="{StaticResource StrongMutedTextColor}"/>
    <SolidColorBrush x:Key="PlaceholderBrush" Color="{StaticResource PlaceholderColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLightColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource StrongMutedTextColor}"/>

    <!-- Sidebar Brushes -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="{StaticResource SidebarTextActiveColor}"/>
    <SolidColorBrush x:Key="SidebarSectionBrush" Color="{StaticResource SidebarSectionColor}"/>

</ResourceDictionary>
