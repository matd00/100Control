<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- LIGHT THEME — Premium SaaS Color Palette               -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <!-- Primary — Modern Indigo -->
    <Color x:Key="PrimaryColor">#6366F1</Color>
    <Color x:Key="PrimaryHoverColor">#4F46E5</Color>
    <Color x:Key="PrimaryLightColor">#EEF2FF</Color>

    <!-- Neutral Palette — Slate scale -->
    <Color x:Key="BackgroundColor">#F8FAFC</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <Color x:Key="BorderSubtleColor">#F1F5F9</Color>

    <!-- Text Hierarchy -->
    <Color x:Key="TextColor">#0F172A</Color>
    <Color x:Key="TextSecondaryColor">#334155</Color>
    <Color x:Key="MutedTextColor">#64748B</Color>
    <Color x:Key="StrongMutedTextColor">#475569</Color>
    <Color x:Key="PlaceholderColor">#94A3B8</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="SuccessLightColor">#ECFDF5</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningLightColor">#FFFBEB</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerLightColor">#FEF2F2</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoLightColor">#EFF6FF</Color>

    <!-- Sidebar (Stays mostly same or darkened) -->
    <Color x:Key="SidebarBgColor">#0C0F1D</Color>
    <Color x:Key="SidebarHoverColor">#1A1F35</Color>
    <Color x:Key="SidebarActiveColor">#6366F1</Color>
    <Color x:Key="SidebarTextColor">#8892B0</Color>
    <Color x:Key="SidebarTextActiveColor">#FFFFFF</Color>
    <Color x:Key="SidebarSectionColor">#4A5280</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="StrongMutedTextBrush" Color="{StaticResource StrongMutedTextColor}"/>
    <SolidColorBrush x:Key="PlaceholderBrush" Color="{StaticResource PlaceholderColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLightColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource StrongMutedTextColor}"/>

    <!-- Sidebar Brushes -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="{StaticResource SidebarTextActiveColor}"/>
    <SolidColorBrush x:Key="SidebarSectionBrush" Color="{StaticResource SidebarSectionColor}"/>

</ResourceDictionary>
